{
    "app-id": "com.example.M3Player",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "m3p_flutter",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=dri",
        "--filesystem=xdg-music",
        "--filesystem=xdg-download"
    ],
    "modules": [
        {
            "name": "libass",
            "cleanup": [ "/include", "/lib/pkgconfig" ],
            "config-opts": [ "--disable-static" ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libass/libass/releases/download/0.17.1/libass-0.17.1.tar.gz",
                    "sha256": "d653be97198a0543c69111122173c41a99e0b91426f9e17f06a858982c2fb03d"
                }
            ]
        },
        {
            "name": "libplacebo",
            "buildsystem": "meson",
            "config-opts": [
                "-Dtests=false",
                "-Ddemos=false",
                "-Dvulkan=enabled",
                "-Dshaderc=disabled",
                "-Dglslang=disabled"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/haasn/libplacebo.git",
                    "tag": "v7.360.1",
                    "commit": "cee9b076f2c63104ccfd497fa79c39a867293ec4"
                }
            ]
        },
        {
            "name": "mpv",
            "buildsystem": "meson",
            "config-opts": [
                "-Dlibmpv=true",
                "-Dcplayer=false",
                "-Dalsa=disabled",
                "-Dlua=disabled",
                "-Djavascript=disabled",
                "-Dmanpage-build=disabled",
                "-Dhtml-build=disabled"
            ],
            "cleanup": [ "/include", "/lib/pkgconfig" ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/mpv-player/mpv/archive/v0.38.0.tar.gz",
                    "sha256": "86d9ef40b6058732f67b46d0bbda24a074fae860b3eaae05bab3145041303066"
                }
            ]
        },
        {
            "name": "m3p",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/m3p",
                "cp -r bundle/* /app/m3p/",
                "mkdir -p /app/bin",
                "ln -s /app/m3p/m3p_flutter /app/bin/m3p_flutter",
                "install -Dm644 com.example.M3Player.desktop /app/share/applications/com.example.M3Player.desktop",
                "install -Dm644 Icon-512.png /app/share/icons/hicolor/512x512/apps/com.example.M3Player.png"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "build/linux/x64/release/bundle",
                    "dest": "bundle"
                },
                {
                    "type": "file",
                    "path": "com.example.M3Player.desktop"
                },
                {
                    "type": "file",
                    "path": "build/web/icons/Icon-512.png"
                }
            ]
        }
    ]
}
